# @broberg/ai-sdk — provider credentials. Copy to .env and fill in.
# Each adapter reads its key from here (dotenv loads .env locally; prod uses fly/env secrets).

# Anthropic (HTTP API transport). Subprocess transport uses the local `claude` CLI / Max plan — no key.
ANTHROPIC_API_KEY=

# OpenAI (chat + Whisper transcription + embeddings)
OPENAI_API_KEY=

# Google Gemini (text, vision, image generation)
GOOGLE_API_KEY=

# DeepInfra (OpenAI-compatible endpoint)
DEEPINFRA_API_KEY=

# OpenRouter (meta-router incl. MiniMax M2.7)
OPENROUTER_API_KEY=

# fal.ai (image generation)
FAL_KEY=

# upmetrics cost sink (X-Upmetrics-Key header). Per-project api_key from the upmetrics enrollment.
UPMETRICS_API_KEY=
UPMETRICS_BASE_URL=https://upmetrics.org
